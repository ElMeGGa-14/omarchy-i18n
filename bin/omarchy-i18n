UPDATEMENU

  # System menu
  cat >> "$ext_file" << 'SYSMENU'

show_system_menu() {
  local screensaver=$(translate "Screensaver")
  local lock=$(translate "Lock")
  local suspend=$(translate "Suspend")
  local hibernate=$(translate "Hibernate")
  local logout=$(translate "Logout")
  local restart=$(translate "Restart")
  local shutdown=$(translate "Shutdown")

  local options="󱄄  $screensaver\n  $lock"
  ! omarchy-toggle-enabled suspend-off && options="$options\n󰒲  $suspend"
  omarchy-hibernation-available && options="$options\n󰤁  $hibernate"
  options="$options\n󰍃  $logout\n󰜉  $restart\n󰐥  $shutdown"

  case $(menu "$(translate "System")" "$options") in
  *"$screensaver"*) omarchy-launch-screensaver force ;;
  *"$lock"*) omarchy-system-lock ;;
  *"$suspend"*) systemctl suspend ;;
  *"$hibernate"*) systemctl hibernate ;;
  *"$logout"*) omarchy-system-logout ;;
  *"$restart"*) omarchy-system-reboot ;;
  *"$shutdown"*) omarchy-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

SYSMENU

  # go_to_menu override — must match on translated names
  cat >> "$ext_file" << 'GOTOMENU'

go_to_menu() {
  local apps=$(translate "Apps")
  local learn=$(translate "Learn")
  local trigger=$(translate "Trigger")
  local toggle=$(translate "Toggle")
  local hardware=$(translate "Hardware")
  local share=$(translate "Share")
  local reminder=$(translate "Reminder")
  local reminder_set=$(translate "Set one")
  local background=$(translate "Background")
  local capture=$(translate "Capture")
  local style=$(translate "Style")
  local theme=$(translate "Theme")
  local screenrecord=$(translate "Screenrecord")
  local setup=$(translate "Setup")
  local power=$(translate "Power Profile")
  local install=$(translate "Install")
  local remove=$(translate "Remove")
  local update=$(translate "Update")
  local about=$(translate "About")
  local system=$(translate "System")

  local choice="${1,,}"
  if [[ $choice == *"${apps,,}"* ]]; then walker -p "Launch…"
  elif [[ $choice == *"${learn,,}"* ]]; then show_learn_menu
  elif [[ $choice == *"${trigger,,}"* ]]; then show_trigger_menu
  elif [[ $choice == *"${toggle,,}"* ]]; then show_toggle_menu
  elif [[ $choice == *"${hardware,,}"* ]]; then show_hardware_menu
  elif [[ $choice == *"${share,,}"* ]]; then show_share_menu
  elif [[ $choice == *"${reminder_set,,}"* ]]; then show_custom_reminder_input
  elif [[ $choice == *"${reminder,,}"* ]]; then show_reminder_menu
  elif [[ $choice == *"${background,,}"* ]]; then show_background_menu
  elif [[ $choice == *"${capture,,}"* ]]; then show_capture_menu
  elif [[ $choice == *"${style,,}"* ]]; then show_style_menu
  elif [[ $choice == *"${theme,,}"* ]]; then show_theme_menu
  elif [[ $choice == *"${screenrecord,,}"* ]]; then show_screenrecord_menu
  elif [[ $choice == *"${setup,,}"* ]]; then show_setup_menu
  elif [[ $choice == *"${power,,}"* ]]; then show_setup_power_menu
  elif [[ $choice == *"${install,,}"* ]]; then show_install_menu
  elif [[ $choice == *"${remove,,}"* ]]; then show_remove_menu
  elif [[ $choice == *"${update,,}"* ]]; then show_update_menu
  elif [[ $choice == *"${about,,}"* ]]; then show_about
  elif [[ $choice == *"${system,,}"* ]]; then show_system_menu
  fi
}

GOTOMENU

  # show_font_menu override — translate prompt
  cat >> "$ext_file" << 'FONTMENU'

show_font_menu() {
  local theme
  theme=$(menu "$(translate "Font")" "$(omarchy-font-list)" "--width 350" "$(omarchy-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    omarchy-font-set "$theme"
  fi
}

show_hardware_touchpad_haptics_menu() {
  local current=$(dell-xps-touchpad-haptics get)
  local selected=$(menu "$(translate "Touchpad Haptics")" "low\nmid\nhigh" "" "$current")
  if [[ -n $selected ]]; then
    dell-xps-touchpad-haptics set "$selected"
  else
    back_to show_hardware_menu
  fi
}

FONTMENU

  # Override helper functions to translate their messages
  cat >> "$ext_file" << 'HELPERS'

open_in_editor() {
  notify-send -u low "$(translate "Editing config file")" "$1"
  omarchy-launch-editor "$1"
}

install() {
  local pkg_name="$1"
  present_terminal "echo '$(translate "Installing") $pkg_name...'; omarchy-pkg-add $2"
}

install_and_launch() {
  local pkg_name="$1"
  present_terminal "echo '$(translate "Installing") $pkg_name...'; omarchy-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  local pkg_name="$1"
  present_terminal "echo '$(translate "Installing") $pkg_name...'; omarchy-pkg-add $2 && sleep 2 && omarchy-font-set '$3'"
}

aur_install() {
  local pkg_name="$1"
  present_terminal "echo '$(translate "Installing") $pkg_name $(translate "from AUR")...'; omarchy-pkg-aur-add $2"
}

aur_install_and_launch() {
  local pkg_name="$1"
  present_terminal "echo '$(translate "Installing") $pkg_name $(translate "from AUR")...'; omarchy-pkg-aur-add $2 && setsid gtk-launch $3"
}

HELPERS

  chmod +x "$ext_file"
  info "Extensión de menú traducido creada: $ext_file"
  info "El menú Omarchy mostrará textos en el idioma seleccionado al abrirlo."
}

# ─── Step 10: Show summary ─────────────────────────────
show_summary() {
  header "Resumen de cambios aplicados"

  echo "  ${G}✓${N} Locale del sistema:      $LOCALE"
  if [[ $CHANGE_KEYBOARD == true ]]; then
    echo "  ${G}✓${N} Disposición de teclado:  $KB_LAYOUT (cambiada)"
  else
    echo "  ${G}✓${N} Disposición de teclado:  US (sin cambios)"
  fi
  if [[ $CLOCK_12H == true ]]; then
    echo "  ${G}✓${N} Formato de reloj:       12H (%I:%M %p)"
  else
    echo "  ${G}✓${N} Formato de reloj:       24H (%H:%M)"
  fi
  echo "  ${G}✓${N} Menú Omarchy:            Traducido"
  echo "  ${G}✓${N} Tooltips de Waybar:      Traducidos"
  echo "  ${G}✓${N} Notificaciones Mako:     Traducidas"
  echo "  ${G}✓${N} Placeholders de Walker:  Traducidos"
  echo
  warn "Algunos cambios requieren reinicio de sesión para aplicarse completamente."
  echo
  info "Consejo: tras ejecutar 'omarchy update', corre 'omarchy-i18n --check'"
  info "para detectar cadenas nuevas que necesiten traducción."
  echo
  echo "  Pasos recomendados:"
  local n=1
  if [[ $CHANGE_KEYBOARD == true ]]; then
    echo "  $((n++)). ${B}hyprctl reload${N}             — recargar configuración de teclado"
  fi
  echo "  $((n++)). ${B}omarchy restart waybar${N}     — aplicar formato de reloj y tooltips"
  echo "  $((n++)). ${B}omarchy restart walker${N}     — aplicar placeholders traducidos"
  echo "  $((n++)). ${B}omarchy restart mako${N}       — aplicar reglas de notificaciones"
  echo "  $((n++)). ${B}Cerrar sesión y volver a entrar${N} — aplicar locale del sistema"
  echo
}

# ─── Check mode: scan original menu for untranslated strings ──
check_translations() {
  header "Verificación de cadenas sin traducir"

  local menu_src="$HOME/.local/share/omarchy/bin/omarchy-menu"
  if [[ ! -f $menu_src ]]; then
    error "No se encuentra $menu_src"
    exit 1
  fi

  echo "¿Para qué idioma verificar las traducciones?"
  local langs=("Español" "Français" "Italiano" "Português" "Русский" "中文")
  local codes=("es_ES.UTF-8" "fr_FR.UTF-8" "it_IT.UTF-8" "pt_PT.UTF-8" "ru_RU.UTF-8" "zh_CN.UTF-8")
  for ((i=0; i<${#langs[@]}; i++)); do
    printf "  ${G}%d)${N} %s\n" $((i+1)) "${langs[i]}"
  done
  echo
  read -r -p "Selecciona un número [1-${#langs[@]}]: " choice
  if [[ $choice -lt 1 || $choice -gt ${#langs[@]} ]]; then
    error "Selección inválida"
    exit 1
  fi
  local selected="${codes[$((choice-1))]}"

  translate_menu "$selected" 2>/dev/null || {
    warn "No hay traducciones para $selected (usa inglés por defecto)"
  }

  info "Escaneando $menu_src ..."

  local unknown=()
  local found=()

  while read -r str; do
    [[ ${#str} -le 2 ]] && continue
    [[ $str == /* || $str == ~* || $str == *'$'* ]] && continue
    [[ $str == https://* || $str == http://* ]] && continue
    [[ $str == \{*\} ]] && continue
    [[ ! $str =~ [[:alnum:]] ]] && continue
    [[ $(printf '%d' "'${str:0:1}" 2>/dev/null) -ge 57344 ]] && continue
    [[ $str == "alacritty" || $str == "foot" || $str == "kitty" || $str == "ghostty" ]] && continue
    [[ $str == -[a-z]* || $str == --[a-z]* ]] && continue
    [[ ${str,,} == "enable" || ${str,,} == "disable" ]] && continue
    [[ $str == "low" || $str == "mid" || $str == "high" ]] && continue

    if [[ -n "${MENU_TR[$str]:-}" ]]; then
      found+=("$str")
    else
      unknown+=("$str")
    fi
  done < <(grep -oP '"[^"]{2,}"' "$menu_src" | tr -d '"' | sort -u)

  for cfg in "$HOME/.config/waybar/config.jsonc" "$HOME/.config/mako/config" "$HOME/.local/share/omarchy/default/mako/core.ini"; do
    [[ ! -f $cfg ]] && continue
    while read -r str; do
      [[ $str == *'$'* || $str == \{*\} ]] && continue
      [[ $str == /* || $str == ./* || $str == *//* ]] && continue
      [[ ! $str =~ [A-Za-z] ]] && continue
      if [[ -z "${MENU_TR[$str]:-}" ]]; then
        unknown+=("$str")
      fi
    done < <(grep -oP '"[^"]{3,}"' "$cfg" | tr -d '"' | sort -u)
  done

  local unique=()
  local seen=""
  for s in "${unknown[@]}"; do
    if [[ $seen != *"[$s]"* ]]; then
      unique+=("$s")
      seen+="[$s]"
    fi
  done

  echo
  if [[ ${#unique[@]} -eq 0 ]]; then
    echo -e "  ${G}✓${N} Todas las cadenas conocidas están traducidas."
  else
    echo -e "  ${Y}${#unique[@]} cadena(s) sin traducción encontrada(s):${N}"
    echo
    for s in "${unique[@]}"; do
      echo "    ${Y}MENU_TR[\"$s\"]=\"\"${N}"
    done
    echo
    echo "  Para agregarlas: edita translate_menu() en ~/.local/bin/omarchy-i18n"
    echo "  copiando esas líneas con la traducción entre comillas, luego"
    echo "  ejecuta 'omarchy-i18n --check' de nuevo para verificar."
    echo "  Cuando estén todas, corre 'omarchy-i18n' (sin sudo si solo cambia menú)."
  fi
  echo
  echo -e "  ${G}${#found[@]}${N} cadenas ya traducidas."
  echo
  info "Consejo: tras 'omarchy update', ejecuta 'omarchy-i18n --check'"
  info "para detectar cadenas nuevas añadidas por la actualización."
}

# ─── Main ──────────────────────────────────────────────
main() {
  echo
  echo -e "${B}╔══════════════════════════════════════════════╗${N}"
  echo -e "${B}║        Omarchy i18n — Localización           ║${N}"
  echo -e "${B}║   Cambia idioma, teclado, reloj y menús      ║${N}"
  echo -e "${B}╚══════════════════════════════════════════════╝${N}"
  echo

  select_language

  # Load translations for the selected locale
  if ! translate_menu "$LOCALE" 2>/dev/null; then
    warn "No hay traducciones para $LOCALE. El menú quedará en inglés."
    echo
  fi

  select_clock_format
  select_keyboard

  echo
  warn "Se requiere sudo para cambiar locale del sistema."
  echo

  apply_locale
  apply_hyprland_input
  apply_waybar_clock
  apply_waybar_tooltips
  apply_mako_rules
  apply_walker_i18n
  apply_menu_extension

  show_summary

  echo -e "${G}✓${N} Localización completada."
  echo "  Para deshacer, restaura los respaldos creados en ~/.config/"
}

# ─── Entry point ────────────────────────────────────────
case "${1:-}" in
  --check|-c)
    check_translations
    exit 0
    ;;
  --watch|-w)
    current_locale=$(grep -E '^LANG=' /etc/locale.conf 2>/dev/null | cut -d= -f2 || echo "en_US.UTF-8")
    translate_menu "$current_locale" 2>/dev/null || true
    new_count=0
    while read -r str; do
      [[ $str == /* || $str == *'$'* || ${#str} -le 2 || ! $str =~ [[:alnum:]] ]] && continue
      if [[ -z "${MENU_TR[$str]:-}" ]]; then
        ((new_count++))
      fi
    done < <(grep -oP '"[^"]{2,}"' "$HOME/.local/share/omarchy/bin/omarchy-menu" 2>/dev/null | tr -d '"' | sort -u)
    if [[ $new_count -gt 0 ]]; then
      notify-send -u normal "Omarchy i18n" "$new_count cadena(s) nueva(s) sin traducir. Corre 'omarchy-i18n --check' para verlas."
    fi
    exit 0
    ;;
  --help|-h)
    echo "Uso: omarchy-i18n [opción]"
    echo "  (sin args)  — ejecuta el asistente de localización completo"
    echo "  --check|-c  — busca cadenas sin traducir en los menús/configs"
    echo "  --watch|-w  — modo silencioso para systemd/cron (notifica si hay novedades)"
    echo
    echo "  Vigilancia automática:"
    echo "    systemctl --user enable --now omarchy-i18n-check.timer"
    echo "    (revisa diariamente y notifica si hay cadenas nuevas)"
    exit 0
    ;;
  --install-watch)
    unit_dir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
    mkdir -p "$unit_dir"
    cat > "$unit_dir/omarchy-i18n-check.service" << 'SERVICE'
[Unit]
Description=Omarchy i18n — check for untranslated strings

[Service]
Type=oneshot
ExecStart=%h/.local/bin/omarchy-i18n --watch
SERVICE
    cat > "$unit_dir/omarchy-i18n-check.timer" << 'TIMER'
[Unit]
Description=Daily check for new untranslated Omarchy strings

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
TIMER
    info "Unidades systemd creadas en $unit_dir"
    info "Actívalas con:"
    info "  systemctl --user daemon-reload"
    info "  systemctl --user enable --now omarchy-i18n-check.timer"
    exit 0
    ;;
esac

main
