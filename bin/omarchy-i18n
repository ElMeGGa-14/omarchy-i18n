show_hardware_menu() {
  local laptop=$(translate "Laptop Display")
  local mirror=$(translate "Mirror Display")
  local options="󰛧  $laptop\n 󰍹  $mirror"

  if omarchy-hw-hybrid-gpu; then
    options="$options\n  $(translate "Hybrid GPU")"
  fi

  if omarchy-hw-touchpad; then
    options="$options\n󰟸  $(translate "Touchpad")"
  fi

  if omarchy-hw-dell-xps-haptic-touchpad && omarchy-cmd-present dell-xps-touchpad-haptics; then
    options="$options\n󰌌  $(translate "Touchpad Haptics")"
  fi

  if omarchy-hw-touchscreen; then
    options="$options\n󰆽  $(translate "Touchscreen")"
  fi

  case $(menu "$(translate "Toggle")" "$options") in
  *"$laptop"*) omarchy-hyprland-monitor-internal toggle ;;
  *"$mirror"*) omarchy-hyprland-monitor-internal-mirror toggle ;;
  *"$(translate "Touchpad Haptics")"*) show_hardware_touchpad_haptics_menu ;;
  *"$(translate "Touchpad")"*) omarchy-toggle-touchpad ;;
  *"$(translate "Touchscreen")"*) omarchy-toggle-touchscreen ;;
  *"$(translate "Hybrid GPU")"*) present_terminal omarchy-toggle-hybrid-gpu ;;
  *) back_to show_trigger_menu ;;
  esac
}

