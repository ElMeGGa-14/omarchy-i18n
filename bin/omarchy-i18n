#!/bin/bash
# omarchy-i18n — Universal language/localization tool for Omarchy
# Changes system locale, keyboard layout, clock format, and translates
# Omarchy menus/notifications safely (only modifies ~/.config/, never ~/.local/share/omarchy/)
#
# Usage: bash omarchy-i18n
# Requires: sudo (for locale-gen and /etc/locale.conf)

set -euo pipefail

# ─── Colores ────────────────────────────────────────────
R=$'\033[1;31m'
G=$'\033[1;32m'
Y=$'\033[1;33m'
B=$'\033[1;34m'
N=$'\033[0m'

info()  { echo -e "${G}[INFO]${N}  $*"; }
warn()  { echo -e "${Y}[WARN]${N}  $*"; }
error() { echo -e "${R}[ERROR]${N} $*"; }
header(){ echo -e "\n${B}━━━ $* ━━━${N}"; }

# ─── Idioma data (locale → teclado → nombre) ───────────
declare -A LOCALE_MAP
LOCALE_MAP=(
  ["Español (España)"]="es_ES.UTF-8:es"
  ["Español (México)"]="es_MX.UTF-8:latam"
  ["Español (Argentina)"]="es_AR.UTF-8:latam"
  ["Español (Colombia)"]="es_CO.UTF-8:latam"
  ["Español (Chile)"]="es_CL.UTF-8:latam"
  ["Français (France)"]="fr_FR.UTF-8:fr"
  ["Français (Canada)"]="fr_CA.UTF-8:ca"
  ["Français (Belgique)"]="fr_BE.UTF-8:be"
  ["Français (Suisse)"]="fr_CH.UTF-8:ch"
  ["Deutsch (Deutschland)"]="de_DE.UTF-8:de"
  ["Deutsch (Österreich)"]="de_AT.UTF-8:at"
  ["Deutsch (Schweiz)"]="de_CH.UTF-8:ch"
  ["Italiano (Italia)"]="it_IT.UTF-8:it"
  ["Italiano (Svizzera)"]="it_CH.UTF-8:ch"
  ["Português (Brasil)"]="pt_BR.UTF-8:br"
  ["Português (Portugal)"]="pt_PT.UTF-8:pt"
  ["Nederlands (Nederland)"]="nl_NL.UTF-8:nl"
  ["Nederlands (België)"]="nl_BE.UTF-8:be"
  ["Polski (Polska)"]="pl_PL.UTF-8:pl"
  ["Русский (Россия)"]="ru_RU.UTF-8:ru"
  ["中文 (简体)"]="zh_CN.UTF-8:cn"
  ["中文 (简体, 新加坡)"]="zh_SG.UTF-8:cn"
  ["中文 (繁體)"]="zh_TW.UTF-8:tw"
  ["日本語 (日本)"]="ja_JP.UTF-8:jp"
  ["한국어 (대한민국)"]="ko_KR.UTF-8:kr"
  ["English (US)"]="en_US.UTF-8:us"
  ["English (UK)"]="en_GB.UTF-8:gb"
)

# ─── Translation data files ──────────────────────
# Each file in ~/.config/omarchy/i18n/<lang>.json contains:
#   phrases — full phrase translations (MENU_TR lookup)
#   words   — word-level translations (fallback for unknown phrases)
declare -A MENU_TR
declare -A WORD_TR

translate_menu() {
  local lang="$1"
  MENU_TR=()
  WORD_TR=()

  local i18n_dir="${XDG_CONFIG_HOME:-$HOME/.config}/omarchy/i18n"
  local matched=""

  for json in "$i18n_dir"/*.json; do
    [[ ! -f $json ]] && continue
    while IFS= read -r locale_pat; do
      if [[ $lang == $locale_pat ]]; then
        matched="$json"
        break 2
      fi
    done < <(grep -oP '"[^"]+\*"' "$json" | tr -d '"')
  done

  if [[ -z $matched ]]; then
    warn "No hay traducciones para '$lang'. Usando inglés."
    return 1
  fi

  # Load phrases into MENU_TR
  local in_phrases=false
  local in_words=false
  while IFS= read -r line; do
    if [[ $line == *'"phrases"'* ]]; then
      in_phrases=true; in_words=false; continue
    elif [[ $line == *'"words"'* ]]; then
      in_phrases=false; in_words=true; continue
    elif [[ $line =~ ^[[:space:]]*\}[,][[:space:]]*$ || $line == '}' ]]; then
      in_phrases=false; in_words=false; continue
    fi

    if $in_phrases && [[ $line =~ \"([^\"]+)\"[[:space:]]*:[[:space:]]*\"(.*)\"(,?) ]]; then
      MENU_TR["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
    elif $in_words && [[ $line =~ \"([^\"]+)\"[[:space:]]*:[[:space:]]*\"(.*)\"(,?) ]]; then
      WORD_TR["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
    fi
  done < "$matched"

  info "Traducciones cargadas desde $(basename "$matched")"
}

# ─── Helper: translate lookup with word-level fallback ──
translate() {
  local key="$1"
  # Quick phrase lookup
  if [[ -n "${MENU_TR[$key]:-}" ]]; then
    echo "${MENU_TR[$key]}"
    return
  fi

  # Word-by-word fallback for unknown phrases
  local result=""
  local word=""
  local first=true
  for word in $key; do
    $first || result+=" "
    first=false
    local lower="${word,,}"
    if [[ -n "${WORD_TR[$lower]:-}" ]]; then
      result+="${WORD_TR[$lower]}"
    else
      result+="$word"
    fi
  done
  echo "$result"
}

# ─── Helper: translate lookup ──────────────────────────
translate() {
  local key="$1"
  echo "${MENU_TR[$key]:-$key}"
}

# ─── Detect current locale ──────────────────────────────
detect_current_locale() {
  if [[ -f /etc/locale.conf ]]; then
    grep -E '^LANG=' /etc/locale.conf | cut -d= -f2 || echo "en_US.UTF-8"
  else
    echo "en_US.UTF-8"
  fi
}

# ─── Step 1: Select language ───────────────────────────
select_language() {
  header "Selección de idioma"

  local i=0
  local keys=()
  echo "Idiomas disponibles:"
  echo "  ${G}0)${N} Salir (sin cambios)"
  for key in "${!LOCALE_MAP[@]}"; do
    i=$((i+1))
    keys[i]="$key"
    printf "  ${G}%d)${N} %s\n" "$i" "$key"
  done

  echo
  local choice
  read -r -p "Selecciona un número [0-${#keys[@]}]: " choice

  if [[ $choice -eq 0 || -z $choice ]]; then
    echo "Cancelado."
    exit 0
  fi

  if [[ $choice -lt 1 || $choice -gt ${#keys[@]} ]]; then
    error "Selección inválida"
    exit 1
  fi

  local selected_name="${keys[$choice]}"
  local data="${LOCALE_MAP[$selected_name]}"
  LOCALE="${data%%:*}"
  KB_LAYOUT_DEFAULT="${data##*:}"

  info "Idioma:    $selected_name"
  info "Locale:    $LOCALE"
}

# ─── Step 2: Select clock format ───────────────────────
select_clock_format() {
  header "Formato de reloj"

  echo "  1) Formato 24H (ej: 14:30) — predeterminado Omarchy"
  echo "  2) Formato 12H (ej: 02:30 PM) — más usado en países hispanos"
  echo
  local choice
  read -r -p "Selecciona 1 o 2 [1]: " choice

  case "${choice:-1}" in
    2) CLOCK_12H=true; info "Formato 12H seleccionado" ;;
    *) CLOCK_12H=false; info "Formato 24H seleccionado" ;;
  esac
}

# ─── Step 3: Select keyboard layout ─────────────────────
select_keyboard() {
  header "Distribución de teclado"

  echo "  El idioma seleccionado usa: ${B}$KB_LAYOUT_DEFAULT${N}"
  echo "  1) Cambiar teclado a $KB_LAYOUT_DEFAULT (recomendado para ese idioma)"
  echo "  2) Mantener teclado actual (US) — el que está configurado ahora"
  echo
  local choice
  read -r -p "Selecciona 1 o 2 [2]: " choice

  case "${choice:-2}" in
    1)
      KB_LAYOUT="$KB_LAYOUT_DEFAULT"
      CHANGE_KEYBOARD=true
      info "Teclado cambiado a: $KB_LAYOUT"
      ;;
    *)
      KB_LAYOUT="us"
      CHANGE_KEYBOARD=false
      info "Teclado mantenido en: us"
      ;;
  esac
}

# ─── Step 4: Generate locale ────────────────────────────
apply_locale() {
  header "Aplicando locale del sistema"

  local locale_clean="${LOCALE%.UTF-8}"

  info "Habilitando $LOCALE en /etc/locale.gen..."
  if sudo sed -i "s/^#[[:space:]]*${locale_clean}.UTF-8/${locale_clean}.UTF-8/" /etc/locale.gen 2>/dev/null; then
    info "Ejecutando locale-gen..."
    sudo locale-gen
  else
    warn "No se pudo modificar /etc/locale.gen. Quizás ya está habilitado."
  fi

  info "Estableciendo LANG=$LOCALE en /etc/locale.conf..."
  echo "LANG=$LOCALE" | sudo tee /etc/locale.conf >/dev/null

  info "Aplicando con localectl..."
  sudo localectl set-locale "LANG=$LOCALE" 2>/dev/null || true

  # Also set LC_TIME so date/time respects locale
  local lc_time="${LOCALE}"
  sudo localectl set-locale "LC_TIME=$lc_time" 2>/dev/null || true

  if [[ $CHANGE_KEYBOARD == true ]]; then
    info "Configurando teclado $KB_LAYOUT..."
    sudo localectl set-x11-keymap "$KB_LAYOUT" 2>/dev/null || true
  fi

  info "Locale aplicado. Los cambios de idioma en apps gráficas requieren reinicio de sesión."
}

# ─── Step 4: Update Hyprland input.conf ────────────────
apply_hyprland_input() {
  if [[ $CHANGE_KEYBOARD != true ]]; then
    info "Teclado no modificado (manteniendo US). Omitiendo Hyprland input.conf."
    return
  fi
  header "Actualizando disposición de teclado en Hyprland"

  local input_conf="$HOME/.config/hypr/input.conf"
  if [[ ! -f $input_conf ]]; then
    warn "No se encontró $input_conf. Creando uno nuevo."
    cat > "$input_conf" << 'HYPRINPUT'
# Control your input devices
# See https://wiki.hypr.land/Configuring/Basics/Variables/#input
input {
  kb_layout = us
  kb_options = compose:caps
  repeat_rate = 40
  repeat_delay = 250
  numlock_by_default = true

  touchpad {
    clickfinger_behavior = true
    scroll_factor = 0.4
  }
}
HYPRINPUT
  fi

  # Backup
  cp "$input_conf" "${input_conf}.bak.$(date +%s)"
  info "Respaldo creado: ${input_conf}.bak.*"

  # Replace kb_layout line
  if grep -q 'kb_layout' "$input_conf"; then
    sed -i "s/^[[:space:]]*kb_layout\s*=.*/  kb_layout = $KB_LAYOUT/" "$input_conf"
  else
    sed -i '/^input {/a\  kb_layout = '"$KB_LAYOUT" "$input_conf"
  fi

  info "kb_layout actualizado a: $KB_LAYOUT"
  info "Recarga Hyprland con 'hyprctl reload' para aplicar."
}

# ─── Step 5: Update Waybar clock ────────────────────────
apply_waybar_clock() {
  header "Actualizando formato de reloj en Waybar"

  local waybar_conf="$HOME/.config/waybar/config.jsonc"
  if [[ ! -f $waybar_conf ]]; then
    warn "No se encontró $waybar_conf. Usando el default de Omarchy."
    waybar_conf="$HOME/.local/share/omarchy/config/waybar/config.jsonc"
  fi

  cp "$waybar_conf" "${waybar_conf}.bak.$(date +%s)"
  info "Respaldo creado: ${waybar_conf}.bak.*"

  if [[ $CLOCK_12H == true ]]; then
    sed -i 's/"format": *"{:L[^}]*}"/"format": "{:L%A %I:%M %p}"/' "$waybar_conf"
    sed -i 's/"format-alt": *"{:L[^}]*}"/"format-alt": "{:L%d %B W%V %Y}"/' "$waybar_conf"
    info "Reloj cambiado a formato 12H (ej: sábado 02:30 PM)"
  else
    sed -i 's/"format": *"{:L[^}]*}"/"format": "{:L%A %H:%M}"/' "$waybar_conf"
    sed -i 's/"format-alt": *"{:L[^}]*}"/"format-alt": "{:L%d %B W%V %Y}"/' "$waybar_conf"
    info "Reloj mantenido en formato 24H (ej: sábado 14:30)"
  fi

  info "Reinicia Waybar con 'omarchy restart waybar' para aplicar."
}

# ─── Step 6: Translate Waybar tooltips ──────────────────
apply_waybar_tooltips() {
  header "Traduciendo tooltips de Waybar"

  local waybar_conf="$HOME/.config/waybar/config.jsonc"
  if [[ ! -f $waybar_conf ]]; then
    warn "No se encontró $waybar_conf. Omitiendo."
    return
  fi

  cp "$waybar_conf" "${waybar_conf}.bak.waybar-i18n.$(date +%s)"
  info "Respaldo creado: ${waybar_conf}.bak.waybar-i18n.*"

  # Translate tooltip-format strings
  local -A TOOLTIPS
  TOOLTIPS=(
    ["Omarchy Menu"]="$(translate "Omarchy Menu\n\nSuper + Alt + Space")"
    ["Omarchy update available"]="$(translate 'Omarchy update available')"
    ["Connected"]="$(translate Connected)"
    ["Disconnected"]="$(translate Disconnected)"
    ["Playing at {volume}%"]="$(translate 'Playing at {volume}%')"
    ["Devices connected: {num_connections}"]="$(translate 'Devices connected: {num_connections}')"
  )

  for eng in "${!TOOLTIPS[@]}"; do
    local trans="${TOOLTIPS[$eng]}"
    if [[ -n $trans && $trans != "$eng" ]]; then
      # Escape for sed
      local eng_escaped
      eng_escaped=$(printf '%s\n' "$eng" | sed 's/[\/&]/\\&/g; s/\n/\\n/g')
      local trans_escaped
      trans_escaped=$(printf '%s\n' "$trans" | sed 's/[\/&]/\\&/g; s/\n/\\n/g')
      sed -i "s/$eng_escaped/$trans_escaped/g" "$waybar_conf"
      info "  '$eng' → '$trans'"
    fi
  done
}

# ─── Step 7: Translate Mako notification rules ──────────
apply_mako_rules() {
  header "Traduciendo reglas de notificaciones Mako"

  local mako_conf="$HOME/.config/mako/config"
  if [[ ! -f $mako_conf ]]; then
    warn "No se encontró $mako_conf. Omitiendo."
    return
  fi

  cp "$mako_conf" "${mako_conf}.bak.mako-i18n.$(date +%s)"
  info "Respaldo creado: ${mako_conf}.bak.mako-i18n.*"

  local -A MAKO_RULES
  MAKO_RULES=(
    ["Setup Wi-Fi"]="$(translate 'Setup Wi-Fi')"
    ["Update System"]="$(translate 'Update System')"
    ["Learn Keybindings"]="$(translate 'Learn Keybindings')"
    ["Install Dictation with Voxtype"]="$(translate 'Install Dictation with Voxtype')"
    ["Screenshot copied & saved"]="$(translate 'Screenshot copied & saved')"
  )

  for eng in "${!MAKO_RULES[@]}"; do
    local trans="${MAKO_RULES[$eng]}"
    if [[ -n $trans && $trans != "$eng" ]]; then
      local eng_escaped
      eng_escaped=$(printf '%s\n' "$eng" | sed 's/[\/&]/\\&/g')
      local trans_escaped
      trans_escaped=$(printf '%s\n' "$trans" | sed 's/[\/&]/\\&/g')
      sed -i "s/$eng_escaped/$trans_escaped/g" "$mako_conf"
      info "  '$eng' → '$trans'"
    fi
  done

  info "Reinicia Mako con 'omarchy restart mako' para aplicar."
}

# ─── Step 8: Translate Walker placeholders ──────────────
apply_walker_i18n() {
  header "Traduciendo placeholders de Walker"

  local walker_conf="$HOME/.config/walker/config.toml"
  if [[ ! -f $walker_conf ]]; then
    warn "No se encontró $walker_conf. Omitiendo."
    return
  fi

  cp "$walker_conf" "${walker_conf}.bak.walker-i18n.$(date +%s)"
  info "Respaldo creado: ${walker_conf}.bak.walker-i18n.*"

  local search_tr
  search_tr=$(translate 'Search...')
  local noresults_tr
  noresults_tr=$(translate 'No Results')

  if [[ -n $search_tr && $search_tr != 'Search...' ]]; then
    sed -i "s/input = \"Search\.\.\.\"/input = \"$search_tr\"/" "$walker_conf"
    info "  'Search...' → '$search_tr'"
  fi
  if [[ -n $noresults_tr && $noresults_tr != 'No Results' ]]; then
    sed -i "s/list = \"No Results\"/list = \"$noresults_tr\"/" "$walker_conf"
    info "  'No Results' → '$noresults_tr'"
  fi

  info "Reinicia Walker con 'omarchy restart walker' para aplicar."
}

# ─── Step 9: Create menu translation extension ─────────
apply_menu_extension() {
  header "Creando extensión de menú traducido"

  local ext_dir="$HOME/.config/omarchy/extensions"
  local ext_file="$ext_dir/menu.sh"

  mkdir -p "$ext_dir"

  # Backup if exists
  if [[ -f $ext_file ]]; then
    cp "$ext_file" "${ext_file}.bak.$(date +%s)"
    info "Respaldo de extensión existente creado."
  fi

  cat > "$ext_file" << 'EXTHEADER'
#!/bin/bash
# Menú traducido — generado por omarchy-i18n
# Este archivo sobreescribe las funciones del menú de Omarchy.

EXTHEADER

  # Write the tr() override and all translated menu functions
  # We need to write the MENU_TR array here too for the extension
  echo "declare -A MENU_TR" >> "$ext_file"

  for key in "${!MENU_TR[@]}"; do
    local val="${MENU_TR[$key]}"
    # Escape for shell string in file
    printf 'MENU_TR[%q]=%q\n' "$key" "$val" >> "$ext_file"
  done

  # Write word-level translation dictionary for fallback
  echo "declare -A WORD_TR" >> "$ext_file"
  for key in "${!WORD_TR[@]}"; do
    local val="${WORD_TR[$key]}"
    printf 'WORD_TR[%q]=%q\n' "$key" "$val" >> "$ext_file"
  done

  cat >> "$ext_file" << 'TRFUNC'

translate() {
  local key="$1"
  if [[ -n "${MENU_TR[$key]:-}" ]]; then
    echo "${MENU_TR[$key]}"
    return
  fi
  local result=""
  local word=""
  local first=true
  for word in $key; do
    $first || result+=" "
    first=false
    local lower="${word,,}"
    if [[ -n "${WORD_TR[$lower]:-}" ]]; then
      result+="${WORD_TR[$lower]}"
    else
      result+="$word"
    fi
  done
  echo "$result"
}

TRFUNC

  # Now we need to write the OVERRIDE functions.
  # Since omarchy-menu sources this at the end, our functions
  # will override the originals.
  # We need to replicate the menu functions but with translated strings.

  # We'll use a trick: generate the translated version of each function
  # by reading the original and substituting strings via sed.
  # But that's fragile. Instead, let's write the key menu functions
  # with translated strings directly.

  # Main menu
  cat >> "$ext_file" << 'MAINMENU'

show_main_menu() {
  local apps=$(translate "Apps")
  local learn=$(translate "Learn")
  local trigger=$(translate "Trigger")
  local style=$(translate "Style")
  local setup=$(translate "Setup")
  local install=$(translate "Install")
  local remove=$(translate "Remove")
  local update=$(translate "Update")
  local about=$(translate "About")
  local system=$(translate "System")
  go_to_menu "$(menu "$(translate "Go")" "󰀻  $apps\n󰧑  $learn\n󱓞  $trigger\n  $style\n  $setup\n󰉉  $install\n󰭌  $remove\n  $update\n  $about\n  $system")"
}

MAINMENU

  # Learn menu
  cat >> "$ext_file" << 'LEARNMENU'

show_learn_menu() {
  local keybindings=$(translate "Keybindings")
  local omarchy=$(translate "Omarchy")
  local hyprland=$(translate "Hyprland")
  local arch=$(translate "Arch")
  local neovim=$(translate "Neovim")
  local bash=$(translate "Bash")
  case $(menu "$(translate "Learn")" "  $keybindings\n  $omarchy\n  $hyprland\n󰣇  $arch\n  $neovim\n󱆃  $bash") in
  *"$keybindings"*) omarchy-menu-keybindings ;;
  *"$omarchy"*) omarchy-launch-webapp "https://learn.omacom.io/2/the-omarchy-manual" ;;
  *"$hyprland"*) omarchy-launch-webapp "https://wiki.hypr.land/" ;;
  *"$arch"*) omarchy-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *"$bash"*) omarchy-launch-webapp "https://devhints.io/bash" ;;
  *"$neovim"*) omarchy-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

LEARNMENU

  # Trigger menu
  cat >> "$ext_file" << 'TRIGGERMENU'

show_trigger_menu() {
  local reminder=$(translate "Reminder")
  local capture=$(translate "Capture")
  local transcode=$(translate "Transcode")
  local share=$(translate "Share")
  local toggle=$(translate "Toggle")
  local hardware=$(translate "Hardware")
  case $(menu "$(translate "Trigger")" "󰔛  $reminder\n  $capture\n󰧸  $transcode\n  $share\n󰔎  $toggle\n  $hardware") in
  *"$reminder"*) show_reminder_menu ;;
  *"$capture"*) show_capture_menu ;;
  *"$transcode"*) omarchy-transcode || back_to show_trigger_menu ;;
  *"$share"*) show_share_menu ;;
  *"$toggle"*) show_toggle_menu ;;
  *"$hardware"*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

TRIGGERMENU

  # Reminder menu
  cat >> "$ext_file" << 'REMINDERMENU'

show_reminder_menu() {
  local set_one=$(translate "Set one")
  local show_all=$(translate "Show all")
  local clear_all=$(translate "Clear all")
  case $(menu "$(translate "Reminder")" "󰔛  $set_one\n󰔛  $show_all\n󰔛  $clear_all") in
  *"$set_one"*) show_custom_reminder_input ;;
  *"$show_all"*) omarchy-reminder show ;;
  *"$clear_all"*) omarchy-reminder clear ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_custom_reminder_input() {
  local invalid=$(translate "Invalid reminder")
  local remind=$(translate "Remind in minutes")
  local minutes
  minutes=$(omarchy-menu-input "$remind")

  if [[ $minutes =~ ^[0-9]+$ ]] && ((minutes > 0)); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    omarchy-notification-send "󰔛" "$invalid" "$(translate "Enter the number of minutes")" -u critical
    show_custom_reminder_input
  else
    back_to show_reminder_menu
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(omarchy-menu-input "$(translate "Reminder message")")

  if [[ -n $message ]]; then
    omarchy-reminder "$minutes" "$message"
  else
    omarchy-reminder "$minutes"
  fi
}

REMINDERMENU

  # Capture menu
  cat >> "$ext_file" << 'CAPTUREMENU'

show_capture_menu() {
  local screenshot=$(translate "Screenshot")
  local screenrecord=$(translate "Screenrecord")
  local text=$(translate "Text Extraction")
  local color=$(translate "Color")
  case $(menu "$(translate "Capture")" "  $screenshot\n  $screenrecord\n󰴑  $text\n󰃉  $color") in
  *"$screenshot"*) omarchy-capture-screenshot ;;
  *"$screenrecord"*) show_screenrecord_menu ;;
  *"$text"*) omarchy-capture-text-extraction ;;
  *"$color"*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_screenrecord_menu() {
  omarchy-capture-screenrecording --stop-recording && exit 0

  local no_audio=$(translate "With no audio")
  local desktop_audio=$(translate "With desktop audio")
  local desktop_mic=$(translate "With desktop + microphone audio")
  local desktop_mic_webcam=$(translate "With desktop + microphone audio + webcam")

  case $(menu "$(translate "Screenrecord")" "  $no_audio\n  $desktop_audio\n  $desktop_mic\n  $desktop_mic_webcam") in
  *"$no_audio"*) omarchy-capture-screenrecording ;;
  *"$desktop_audio"*) omarchy-capture-screenrecording --with-desktop-audio ;;
  *"$desktop_mic"*) omarchy-capture-screenrecording --with-desktop-audio --with-microphone-audio ;;
  *"$desktop_mic_webcam"*)
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    omarchy-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "$(translate "No webcam devices found")" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "$(translate "Select Webcam")" "$devices" | awk '{print $1}'
  fi
}

